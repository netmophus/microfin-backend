ENV=dev
DATABASE_URL=postgresql+psycopg://mifin:mifin@localhost:5432/mifin
REDIS_URL=redis://localhost:6379/0

# Clé de signature des jetons JWT. Aucune valeur ici : ce fichier est public.
# Générer avec : openssl rand -hex 32
# Minimum 32 caractères, sinon l'application refuse de démarrer (RFC 7518 §3.2).
# CHAQUE installation IMF doit avoir SON secret : deux installations qui partagent
# cette clé rendent leurs jetons interchangeables d'une IMF à l'autre.
JWT_SECRET=à-générer-avec-openssl-rand-hex-32